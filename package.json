{
  "name": "fermentrack",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build --filter=@fermentrack/web",
    "lint": "turbo run lint",
    "postinstall": "npm run build --workspace=@fermentrack/ui",
    "storybook": "turbo run storybook --filter=@fermentrack/storybook",
    "build-storybook": "turbo run build-storybook --filter=@fermentrack/storybook",
    "setup:claude-mcp": "node scripts/setup-claude-mcp.mjs",
    "check:prod-schema": "node scripts/check-prod-schema.mjs",
    "apply:prod-migrations": "node scripts/apply-pending-prod-migrations.mjs",
    "check:dist-schema": "node scripts/check-dist-schema.mjs",
    "check:mcp-audit": "node scripts/check-mcp-audit.mjs",
    "probe:mcp-audit": "node scripts/probe-mcp-audit.mjs",
    "check:fase2-rpcs": "node scripts/check-fase2-rpcs.mjs"
  },
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": "20.x"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.35",
    "pg": "^8.16.0",
    "prettier": "^3.2.0",
    "turbo": "latest",
    "typescript": "^5.4.0"
  }
}
