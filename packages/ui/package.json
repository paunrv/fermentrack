{
  "name": "@fermentrack/ui",
  "version": "0.0.1",
  "private": true,
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./src/styles/styles.css",
    "./tokens.css": "./src/styles/tokens.css",
    "./tailwind": "./tailwind.preset.js"
  },
  "scripts": {
    "build": "tsup && npm run copy:css",
    "copy:css": "mkdir -p dist && cp src/styles/tokens.css src/styles/components.css dist/ && cat dist/tokens.css dist/components.css > dist/styles.css",
    "dev": "tsup --watch --onSuccess \"npm run copy:css\"",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@fermentrack/typescript-config": "*",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.4.0",
    "typescript": "^5.4.0"
  }
}
