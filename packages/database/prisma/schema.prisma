generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── TENANT ──────────────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(uuid())
  slug      String   @unique
  name      String
  plan      String   @default("starter")
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users         User[]
  batches       Batch[]
  recipes       Recipe[]
  rawMaterials  RawMaterial[]
  warehouses    Warehouse[]
  domainEvents  DomainEvent[]
  auditLogs     AuditLog[]
  skus          Sku[]

  @@map("organizations")
}

model User {
  id             String   @id @default(uuid())
  clerkId        String   @unique @map("clerk_id")
  organizationId String   @map("organization_id")
  email          String
  name           String
  role           UserRole @default(VIEWER)
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("users")
}

enum UserRole {
  OWNER
  ADMIN
  CELLAR_MASTER
  WAREHOUSE_OPS
  QA
  VIEWER
  AUDITOR
}

// ─── PRODUCTION ──────────────────────────────────────────────────────────────

model Recipe {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  name           String
  productType    String   @map("product_type")
  description    String?
  targetLiters   Decimal  @map("target_liters") @db.Decimal(10, 2)
  targetAlcohol  Decimal? @map("target_alcohol") @db.Decimal(5, 2)
  steps          Json     @default("[]")
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  batches      Batch[]

  @@map("recipes")
}

model Batch {
  id              String     @id @default(uuid())
  organizationId  String     @map("organization_id")
  recipeId        String?    @map("recipe_id")
  batchCode       String     @map("batch_code")
  initialLiters   Decimal    @map("initial_liters") @db.Decimal(10, 3)
  currentLiters   Decimal    @map("current_liters") @db.Decimal(10, 3)
  alcoholPct      Decimal?   @map("alcohol_pct") @db.Decimal(5, 2)
  state           BatchState @default(CREATED)
  totalLossLiters Decimal    @default(0) @map("total_loss_liters") @db.Decimal(10, 3)
  lossBreakdown   Json       @default("{}") @map("loss_breakdown")
  eventSequence   Int        @default(0) @map("event_sequence")
  notes           String?
  startedAt       DateTime   @default(now()) @map("started_at")
  closedAt        DateTime?  @map("closed_at")
  createdBy       String     @map("created_by")
  metadata        Json       @default("{}")

  organization  Organization   @relation(fields: [organizationId], references: [id])
  recipe        Recipe?        @relation(fields: [recipeId], references: [id])
  losses        BatchLoss[]
  finishedGoods FinishedGoods[]
  domainEvents  DomainEvent[]

  @@unique([organizationId, batchCode])
  @@map("batches")
}

enum BatchState {
  CREATED
  FERMENTING
  CONDITIONING
  FILTERING
  BOTTLING
  BOTTLED
  CLOSED
  DESTROYED
}

model BatchLoss {
  id         String   @id @default(uuid())
  batchId    String   @map("batch_id")
  lossType   LossType @map("loss_type")
  litersLost Decimal  @map("liters_lost") @db.Decimal(10, 3)
  reason     String?
  recordedBy String   @map("recorded_by")
  recordedAt DateTime @default(now()) @map("recorded_at")
  metadata   Json     @default("{}")

  batch Batch @relation(fields: [batchId], references: [id])

  @@map("batch_losses")
}

enum LossType {
  EVAPORATION
  SAMPLING
  CONTAMINATION
  TRANSFER
  WASTE
  UNACCOUNTED
}

// ─── INVENTORY ───────────────────────────────────────────────────────────────

model RawMaterial {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  name           String
  category       String
  supplierId     String?   @map("supplier_id")
  quantity       Decimal   @db.Decimal(12, 3)
  unit           String
  costPerUnit    Decimal?  @map("cost_per_unit") @db.Decimal(10, 4)
  lotNumber      String?   @map("lot_number")
  receivedAt     DateTime  @default(now()) @map("received_at")
  expiresAt      DateTime? @map("expires_at")
  metadata       Json      @default("{}")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("raw_materials")
}

model Sku {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")
  code           String
  name           String
  volumeMl       Int    @map("volume_ml")
  packagingType  String @map("packaging_type")
  casePack       Int    @default(12) @map("case_pack")
  metadata       Json   @default("{}")

  organization  Organization   @relation(fields: [organizationId], references: [id])
  finishedGoods FinishedGoods[]

  @@unique([organizationId, code])
  @@map("skus")
}

model FinishedGoods {
  id        String   @id @default(uuid())
  batchId   String   @map("batch_id")
  skuId     String   @map("sku_id")
  bottles   Int      @default(0)
  cases     Int      @default(0)
  bottledAt DateTime @default(now()) @map("bottled_at")

  batch   Batch    @relation(fields: [batchId], references: [id])
  sku     Sku      @relation(fields: [skuId], references: [id])
  pallets Pallet[]

  @@map("finished_goods")
}

// ─── WAREHOUSE ───────────────────────────────────────────────────────────────

model Warehouse {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")
  name           String
  address        String?
  metadata       Json   @default("{}")

  organization Organization  @relation(fields: [organizationId], references: [id])
  zones        WarehouseZone[]

  @@map("warehouses")
}

model WarehouseZone {
  id          String   @id @default(uuid())
  warehouseId String   @map("warehouse_id")
  name        String
  code        String
  tempMin     Decimal? @map("temp_min") @db.Decimal(5, 2)
  tempMax     Decimal? @map("temp_max") @db.Decimal(5, 2)
  totalBays   Int      @default(0) @map("total_bays")
  metadata    Json     @default("{}")

  warehouse Warehouse           @relation(fields: [warehouseId], references: [id])
  locations WarehouseLocation[]

  @@map("warehouse_zones")
}

model WarehouseLocation {
  id       String  @id @default(uuid())
  zoneId   String  @map("zone_id")
  aisle    String
  bay      Int
  level    Int
  occupied Boolean @default(false)
  metadata Json    @default("{}")

  zone    WarehouseZone @relation(fields: [zoneId], references: [id])
  pallets Pallet[]

  @@unique([zoneId, aisle, bay, level])
  @@map("warehouse_locations")
}

model Pallet {
  id              String       @id @default(uuid())
  palletCode      String       @unique @map("pallet_code")
  finishedGoodsId String       @map("finished_goods_id")
  locationId      String?      @map("location_id")
  cases           Int
  status          PalletStatus @default(IN_WAREHOUSE)
  createdAt       DateTime     @default(now()) @map("created_at")
  metadata        Json         @default("{}")

  finishedGoods FinishedGoods      @relation(fields: [finishedGoodsId], references: [id])
  location      WarehouseLocation? @relation(fields: [locationId], references: [id])

  @@map("pallets")
}

enum PalletStatus {
  IN_WAREHOUSE
  STAGED
  SHIPPED
  DESTROYED
}

// ─── EVENT SOURCING ───────────────────────────────────────────────────────────

model DomainEvent {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  aggregateType  String   @map("aggregate_type")
  aggregateId    String   @map("aggregate_id")
  eventType      String   @map("event_type")
  payload        Json     @default("{}")
  actorId        String?  @map("actor_id")
  sequence       Int
  correlationId  String?  @map("correlation_id")
  causationId    String?  @map("causation_id")
  occurredAt     DateTime @default(now()) @map("occurred_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  batch        Batch?       @relation(fields: [aggregateId], references: [id], map: "fk_domain_event_batch")

  @@index([aggregateId, sequence])
  @@index([organizationId, occurredAt(sort: Desc)])
  @@index([organizationId, eventType, occurredAt(sort: Desc)])
  @@map("domain_events")
}

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  eventId        String   @map("event_id")
  eventType      String   @map("event_type")
  entityType     String   @map("entity_type")
  entityId       String   @map("entity_id")
  actorId        String?  @map("actor_id")
  actorEmail     String?  @map("actor_email")
  actorRole      String?  @map("actor_role")
  summary        String
  occurredAt     DateTime @default(now()) @map("occurred_at")
  ipAddress      String?  @map("ip_address")
  metadata       Json     @default("{}")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, occurredAt(sort: Desc)])
  @@index([entityId])
  @@map("audit_logs")
}
