# Copy to .env.local and fill in real values (never commit .env.local)

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Solo servidor — nunca NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=eyJ...

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Stripe (winemaker billing — Epic E5)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_WINEMAKER_PRO_MONTHLY=price_...
STRIPE_PRICE_WINEMAKER_PRO_ANNUAL=price_...
# Legacy alias (monthly):
# STRIPE_PRICE_WINEMAKER_PRO=price_...
# Founding cohort — Stripe coupon (duration: forever, annual checkout only)
# STRIPE_COUPON_FOUNDING=coupon_...

# URL pública del sitio (checkout success/cancel + auth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Celular en la misma Wi‑Fi: abre http://TU_IP_LOCAL:3000 (no localhost).
# La IP cambia al cambiar de red — vuelve a añadirla en Supabase si falla el login.
# Supabase Dashboard → Authentication → URL Configuration → Redirect URLs:
#   http://localhost:3000/auth/callback
#   http://localhost:3000/auth/callback?flow=team
#   http://TU_IP_LOCAL:3000/auth/callback
#   http://TU_IP_LOCAL:3000/auth/callback?flow=team
#   http://localhost:3000/auth/confirm
#   http://localhost:3000/auth/confirm?flow=team
# OAuth redirectTo debe ser path limpio (/auth/callback), sin ?intent=…
# Wildcard útil en dev: http://127.0.0.1:3000/** y http://TU_IP_LOCAL:3000/**

# MCP rate limits (optional — defaults: 120 requests / 60s per user)
# MCP_RATE_LIMIT_MAX=120
# MCP_RATE_LIMIT_WINDOW_MS=60000
# Advertise Supabase Auth as MCP OAuth authorization server (requires
# Authentication → OAuth Server enabled in the Supabase dashboard + consent UI).
# Leave unset/false while using bearer JWTs from the browser session.
# PROOF_MCP_OAUTH_ENABLED=true
